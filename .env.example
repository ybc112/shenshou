BSC_RPC_URL=
BSC_TESTNET_RPC_URL=
PRIVATE_KEY=
BSCSCAN_API_KEY=

# Platform treasury. FEE_RECIPIENT is kept compatible with the kaola env naming.
TREASURY=
FEE_RECIPIENT=

# Use either wei or BNB format. CREATION_FEE_WEI takes priority.
CREATION_FEE_WEI=
CREATION_FEE_BNB=

# Leave empty when you do not want to expose a fixed RPC in frontend config.
FRONTEND_RPC_URL=

# Optional: resume a BSC deploy after TokenDeployer already exists.
TOKEN_DEPLOYER_ADDRESS=
