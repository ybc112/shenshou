{
  "name": "ruyi-beast-launchpad",
  "version": "0.1.0",
  "private": true,
  "description": "Ruyi Beast Launchpad smart contracts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "deploy": "hardhat run scripts/deploy.js",
    "node": "hardhat node",
    "deploy:local": "set FRONTEND_RPC_URL=http://127.0.0.1:8545&& hardhat run scripts/deploy.js --network localhost",
    "seed:local": "hardhat run scripts/seed.js --network localhost",
    "web": "npx --yes http-server web -p 5173 -a 127.0.0.1 -c-1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@openzeppelin/contracts": "^5.0.2",
    "ethers": "^6.13.5",
    "hardhat": "^2.26.5"
  }
}
